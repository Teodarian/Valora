{
  "version": 2,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/demo-frisor", "dest": "/demo-frisor.html" },
    { "src": "/demo-gym", "dest": "/demo-gym.html" },
    { "src": "/demo-restaurant", "dest": "/demo-restaurant.html" }
  ]
}
